# Production .env for server deployment
# Copy to .env on the server and fill in real values:
#   cp .env.production.example .env

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False

# Your server IP or domain (comma-separated, no spaces)
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,backend
CORS_ALLOWED_ORIGINS=http://your-domain.com,https://your-domain.com

# PostgreSQL (used by docker-compose db service)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=studira
DB_USER=postgres
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

# Redis / Celery (overridden in docker-compose, kept for reference)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

TIME_ZONE=Europe/Moscow

# Ports (production: only frontend is public)
FRONTEND_PORT=80
# BACKEND_PORT=8000  # leave unset in production — backend is internal only
